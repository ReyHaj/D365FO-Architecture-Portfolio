[ExtensionOf(tableStr(TaxRegistration))]
public final class TaxRegistration_Extension
{
    public boolean validateWrite()
    {
        boolean isValid = next validateWrite();

        // کلمه Tax از اول نام فیلد حذف شد و به RegistrationNumber تغییر یافت
        if (this.RegistrationNumber && strLen(this.RegistrationNumber) != 10)
        {
            isValid = checkFailed("Tax exempt number must be exactly 10 digits.");
        }

        return isValid;
    }
}
