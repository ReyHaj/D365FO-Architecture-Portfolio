[ExtensionOf(tableStr(TaxRegistration))]
public final class TaxRegistration_MyCompany_Extension
{
    public boolean validateWrite()
    {
        boolean isValid = next validateWrite();

        if (this.RegistrationNumber && strLen(this.RegistrationNumber) != 10)
        {
            isValid = checkFailed("Error: The Registration ID must be exactly 10 digits.");
        }

        return isValid;
    }
}
