[ExtensionOf(tableStr(CustTable))]
public final class CustTable_MyCompany_Extension
{
    public boolean validateWrite()
    {
        info(">>> My Custom Code is Running! <<<");

        boolean isValid = next validateWrite();

        if (this.VATNum && strLen(this.VATNum) != 10)
        {
            checkFailed("Validation failed: Tax ID must be exactly 10 digits.");
            isValid = false;
        }

        return isValid;
    }
}
